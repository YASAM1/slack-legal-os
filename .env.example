# =============================================================================
# Slack Legal OS — environment variables
# Copy to .env.local for local dev. In production, set these in Vercel.
# =============================================================================

# --- Database (Neon Postgres via Vercel Marketplace) ---
# Auto-injected when you install the Neon integration. Override locally if needed.
# DATABASE_URL is the pooled connection (used by the app at runtime).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# DATABASE_URL_UNPOOLED is the direct connection (used for migrations / drizzle-kit).
# Neon's Vercel integration injects both automatically.
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# --- Encryption ---
# 32-byte hex key used to encrypt sensitive values at rest (e.g. Clio refresh token).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Admin auth (Clerk) ---
# Get these from https://dashboard.clerk.com after creating your app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Routes for self-hosted sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin
# Comma-separated list of emails allowed into /admin
ADMIN_ALLOWED_EMAILS=you@example.com

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
# Optional, only if using socket mode (we don't, but kept for completeness)
SLACK_APP_TOKEN=xapp-

# --- Clio ---
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
# Region-specific. Use https://app.clio.com for US, https://eu.app.clio.com for EU.
CLIO_BASE_URL=https://app.clio.com
# Set to the full deployment URL of /api/clio/auth/callback (must match Clio app config)
CLIO_REDIRECT_URI=http://localhost:3000/api/clio/auth/callback

# --- AI Gateway (Vercel) ---
# Used for both chat completions (Claude) and embeddings (OpenAI).
AI_GATEWAY_API_KEY=
# Defaults for the agent and capability codegen.
AGENT_MODEL=anthropic/claude-sonnet-4.6
CODEGEN_MODEL=anthropic/claude-opus-4.7
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Perplexity (web search primitive) ---
PERPLEXITY_API_KEY=

# --- Vercel platform secrets ---
# Auto-set by Vercel in production; needed for cron auth.
CRON_SECRET=
# Auto-set by Vercel for Blob uploads.
BLOB_READ_WRITE_TOKEN=

# --- Vercel Sandbox (capability dry-run + scheduled execution) ---
# Per Vercel Sandbox docs; set if not auto-provisioned in your team.
VERCEL_OIDC_TOKEN=
