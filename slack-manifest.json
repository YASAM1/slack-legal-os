{
  "display_information": {
    "name": "Legal OS",
    "description": "AI agent for law firm operations."
  },
  "features": {
    "bot_user": {
      "display_name": "Legal OS",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/legal-os",
        "url": "https://slack-setup-os.vercel.app/api/webhooks/slack",
        "description": "Ask Legal OS something",
        "usage_hint": "[your question]"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "files:write",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "reactions:read",
        "reactions:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://slack-setup-os.vercel.app/api/webhooks/slack",
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "member_joined_channel"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://slack-setup-os.vercel.app/api/webhooks/slack"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
